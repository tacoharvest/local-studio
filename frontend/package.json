{
  "name": "frontend",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "node scripts/start-standalone.mjs",
    "start:next": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "depcheck": "depcheck --ignores=\"@types/react,@types/react-dom,@types/node,eslint-config-next,tailwindcss,@tailwindcss/postcss,depcheck,prettier,husky,jscpd,knip,lint-staged,rehype-highlight,concurrently,cross-env,electron-builder,wait-on,@vitest/coverage-v8,madge\" --ignore-patterns=\"*.d.ts,.next/**,playwright-report/**,coverage/**,dist-desktop/**,desktop/dist/**\" --specials=next,webpack,babel --skip-missing",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run --passWithNoTests",
    "test:integration": "playwright test",
    "prepare": "cd .. && git rev-parse --git-dir >/dev/null 2>&1 && npm run setup:git-hooks || true",
    "check": "knip && jscpd src && npm run depcheck",
    "check:deadcode": "knip",
    "check:dupes": "jscpd src",
    "check:cleanup": "npm run check:deadcode && npm run check:dupes && npm run depcheck",
    "check:fix": "knip --fix",
    "desktop:build:main": "tsc -p desktop/tsconfig.json",
    "desktop:start": "electron desktop/dist/main.js",
    "desktop:start:dev": "VLLM_STUDIO_DESKTOP_DEV_SERVER_URL=http://127.0.0.1:3000 electron desktop/dist/main.js",
    "desktop:build": "npm run build && npm run desktop:build:main",
    "desktop:dev": "npm run desktop:build:main && concurrently -k -n NEXT,ELECTRON -c cyan,magenta \"npm run dev\" \"node -e \\\"setTimeout(() => process.exit(0), 3000)\\\" && npm run desktop:start:dev\"",
    "desktop:dist": "npm run desktop:build && npm run desktop:prepare-pi && electron-builder --config desktop/electron-builder.yml",
    "desktop:pack": "npm run desktop:build && npm run desktop:prepare-pi && electron-builder --dir --config desktop/electron-builder.yml",
    "desktop:prepare-pi": "node scripts/prepare-pi-runtime.mjs",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:desktop": "tsc -p desktop/tsconfig.json",
    "check:cycles": "madge --extensions ts,tsx --circular src",
    "check:static": "npm run lint && npm run typecheck && npm run typecheck:desktop && npm run check:cycles",
    "check:quality": "npm run check:static && npm test && npm run check:cleanup && npm run build",
    "check:quality:full": "npm run check:quality && npm run test:coverage && npm run test:integration",
    "precommit": "lint-staged --config .lintstagedrc.json && npm run typecheck"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "electron-updater": "^6.6.2",
    "highlight.js": "11.11.1",
    "lucide-react": "^0.561.0",
    "next": "^16.1.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "typebox": "^1.1.34",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.3",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-plugin-boundaries": "^5.3.1",
    "husky": "9.1.7",
    "jscpd": "^4.0.5",
    "jsdom": "^26.1.0",
    "knip": "^5.44.2",
    "lint-staged": "15.2.11",
    "madge": "^8.0.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@mistralai/mistralai": "2.2.1"
  },
  "main": "desktop/dist/main.js"
}
