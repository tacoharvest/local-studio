{
  "name": "frontend",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "node scripts/start-standalone.mjs",
    "start:next": "next start",
    "test": "tsx --test scripts/test-build-agent-session-options.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "depcheck": "depcheck --ignores=\"@types/react,@types/react-dom,@types/node,eslint-config-next,tailwindcss,@tailwindcss/postcss,depcheck,prettier,husky,jscpd,knip,lint-staged,rehype-highlight,concurrently,cross-env,electron-builder,madge,tsx\" --ignore-patterns=\"*.d.ts,.next/**,dist-desktop/**,desktop/dist/**\" --specials=next,webpack,babel --skip-missing",
    "analyze": "ANALYZE=true next build",
    "prepare": "cd .. && git rev-parse --git-dir >/dev/null 2>&1 && npm run setup:git-hooks || true",
    "check": "knip && jscpd src && npm run depcheck",
    "check:deadcode": "knip",
    "check:dupes": "jscpd src",
    "check:cleanup": "npm run check:deadcode && npm run check:dupes && npm run depcheck",
    "check:fix": "knip --fix",
    "desktop:build:main": "tsc -p desktop/tsconfig.json",
    "desktop:start": "electron desktop/dist/main.js",
    "desktop:start:dev": "VLLM_STUDIO_DESKTOP_DEV_SERVER_URL=http://127.0.0.1:3000 electron desktop/dist/main.js",
    "desktop:start:dev:beta": "VLLM_STUDIO_DESKTOP_APP_NAME=\"vLLM Studio Dev\" VLLM_STUDIO_DESKTOP_USER_DATA_DIR=\"$HOME/Library/Application Support/vLLM Studio Dev\" VLLM_STUDIO_DESKTOP_CHANNEL=beta VLLM_STUDIO_DESKTOP_DISABLE_AUTO_UPDATE=true VLLM_STUDIO_DESKTOP_DEV_SERVER_URL=http://127.0.0.1:3001 electron desktop/dist/main.js",
    "desktop:build": "npm run build && npm run desktop:build:main",
    "desktop:dev": "npm run desktop:build:main && concurrently -k -n NEXT,ELECTRON -c cyan,magenta \"npm run dev\" \"node -e \\\"setTimeout(() => process.exit(0), 3000)\\\" && npm run desktop:start:dev\"",
    "desktop:dev:beta": "npm run desktop:build:main && concurrently -k -n NEXT,ELECTRON -c cyan,magenta \"PORT=3001 npm run dev\" \"node -e \\\"setTimeout(() => process.exit(0), 3000)\\\" && npm run desktop:start:dev:beta\"",
    "desktop:dist": "npm run desktop:build && electron-builder --config desktop/electron-builder.yml",
    "desktop:pack": "npm run desktop:build && electron-builder --dir --config desktop/electron-builder.yml",
    "typecheck": "tsc --noEmit",
    "typecheck:desktop": "tsc -p desktop/tsconfig.json",
    "check:cycles": "madge --extensions ts,tsx --circular src",
    "check:static": "npm run lint && npm run typecheck && npm run typecheck:desktop && npm run check:cycles",
    "check:quality": "node scripts/validate-package-json.mjs && npm run check:static && npm run check:cleanup && npm run build",
    "check:quality:full": "npm run check:quality",
    "precommit": "lint-staged --config .lintstagedrc.json && npm run typecheck"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.75.5",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.13.0-beta.220",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.6.2",
    "highlight.js": "11.11.1",
    "lucide-react": "^0.561.0",
    "next": "^16.1.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.1",
    "typebox": "^1.1.34",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-plugin-boundaries": "^5.3.1",
    "husky": "9.1.7",
    "jscpd": "^4.0.5",
    "knip": "^5.44.2",
    "lint-staged": "15.2.11",
    "madge": "^8.0.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "overrides": {
    "@mistralai/mistralai": "2.2.1"
  },
  "main": "desktop/dist/main.js"
}
