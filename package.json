{
  "name": "frontend",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "release:notes": "node scripts/release-statement.mjs",
    "release:notes:week": "node scripts/release-statement.mjs --since '1 week ago'",
    "release:check-commits": "node scripts/check-conventional-commits.mjs --range origin/main..HEAD",
    "setup:git-hooks": "git config core.hooksPath .githooks && chmod +x .githooks/*",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "frontend:check": "npm --prefix frontend run check:quality",
    "check": "npm run frontend:lint && npm run frontend:typecheck"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.24.10",
    "lucide-react": "^0.561.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^10.9.5",
    "next": "^16.1.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.18.1",
    "zustand": "^4.5.4"
  },
  "main": "desktop/dist/main.js"
}
