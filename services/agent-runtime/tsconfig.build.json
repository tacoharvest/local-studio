{
  // Emit config for the standalone :8081 server (node dist/server.js). The
  // sibling tsconfig.json (noEmit) stays the editor/typecheck config for the
  // raw-TS transpilePackages consumption by Next — this file must not disturb
  // that path: it only ADDS a dist/ output.
  //
  // rootDir is the repo root because the package sources import
  // ../../shared/agent/* relatively; the emitted tree is therefore
  //   dist/services/agent-runtime/src/**  +  dist/shared/agent/**
  // and scripts/postbuild.mjs writes a dist/server.js entry shim plus the
  // .js specifier extensions node ESM requires (tsc does not rewrite them).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "../..",
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    // The sources use fetch/Headers/ReadableStream types the way the frontend
    // program does (its lib includes dom); mirror that here.
    "lib": ["esnext", "dom"],
    "paths": {
      "effect": ["../../frontend/node_modules/effect"],
      // Point at @types/ws (not the ws implementation dir) so the build sees
      // the type declarations; runtime resolution still finds the real ws via
      // the services/node_modules -> frontend/node_modules bridge.
      "ws": ["../../frontend/node_modules/@types/ws"],
      "hono": ["../../frontend/node_modules/hono"],
      "@hono/node-server": ["../../frontend/node_modules/@hono/node-server"],
      "@earendil-works/pi-ai": ["../../frontend/node_modules/@earendil-works/pi-ai"],
      "@earendil-works/pi-coding-agent": [
        "../../frontend/node_modules/@earendil-works/pi-coding-agent"
      ]
    }
  },
  "include": ["src/**/*.ts", "typings/*.d.ts", "../../shared/agent/**/*.ts"]
}
